# --- Public install identity ---
INSTALL_DOMAIN=example.com
SORI_SERVER_NAME=Sori Server

# --- Public URLs ---
PUBLIC_WEB_URL=https://example.com
PUBLIC_API_URL=https://api.example.com
PUBLIC_WS_URL=wss://api.example.com
PUBLIC_LIVEKIT_URL=wss://livekit.example.com
PUBLIC_MEDIA_URL=https://media.example.com
PUBLIC_DEFAULT_COMMUNITY_ID=default-community

# --- Frontend build-time URLs ---
VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://api.example.com
VITE_LIVEKIT_URL=wss://livekit.example.com
VITE_MAX_UPLOAD_SIZE_MB=25

# --- Gateway / discovery ---
SORI_WEB_HOST=example.com
SORI_API_HOST=api.example.com
SORI_LIVEKIT_HOST=livekit.example.com
SORI_MEDIA_HOST=media.example.com
SORI_GATEWAY_CADDYFILE=./infrastructure/caddy/Caddyfile.production
SORI_LIVEKIT_CONFIG=./infrastructure/livekit.production.yaml
CADDY_ACME_EMAIL=admin@example.com
ALLOWED_ORIGINS=https://example.com

# --- App runtime ---
PORT=3000
NODE_ENV=production
JWT_SECRET=replace-me
MAX_UPLOAD_SIZE_MB=25
LOG_RETENTION_DAYS=7

# --- Postgres ---
POSTGRES_USER=sori
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=sori
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1
DATABASE_URL=postgres://sori:replace-me@postgres:5432/sori

# --- Valkey ---
VALKEY_URL=redis://valkey:6379
VALKEY_PORT=6379
VALKEY_BIND_ADDRESS=127.0.0.1

# --- MinIO / S3 ---
S3_ENDPOINT=http://sori-media:9000
S3_PUBLIC_URL=https://media.example.com
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_BUCKET=sori-media
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BIND_ADDRESS=127.0.0.1

# --- LiveKit ---
LIVEKIT_URL=http://sori-livekit:7880
LIVEKIT_API_KEY=sori-livekit
LIVEKIT_API_SECRET=replace-me
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT=7882
LIVEKIT_BIND_ADDRESS=0.0.0.0

# --- Hidden adminpanel bootstrap ---
ADMIN_PANEL_LOGIN=replace-me
ADMIN_PANEL_PASSWORD=replace-me
ADMIN_PANEL_EMAIL=adminpanel@example.com
