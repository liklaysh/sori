#!/usr/bin/env sh
echo "🛡️ [Husky] Running strict pre-push security audit..."
if grep -rnE "localhost|127.0.0.1|password|secret" . --exclude-dir=node_modules --exclude-dir=tests --exclude=.env.example --exclude=config.ts; then
  echo "❌ [Critical] Sensitive data or local addresses detected! Push blocked."
  exit 1
fi
echo "✅ Security audit passed."

